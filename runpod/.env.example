# RunPod LoRA 訓練 launcher 設定範本。
# 複製成 .env 後填值；.env 不入版控（見 .gitignore）。

# ── RunPod ───────────────────────────────────────────────
# RunPod API key（Console → Settings → API Keys）。必填。
RUNPOD_API_KEY=

# 預先建立好的 Network Volume 識別碼。必填。
# launcher 不會幫你建 volume，請先到 Console → Storage → Network Volume 建立。
RUNPOD_NETWORK_VOLUME_ID=

# Network Volume 所在資料中心（如 EU-RO-1）。必填。
# pod 必須開在同一資料中心才掛得上 volume。
RUNPOD_DATA_CENTER_ID=

# GPU 型別 ID（如 "NVIDIA RTX A6000"）。必填。訓練建議 48GB 以上。
RUNPOD_GPU_TYPE=NVIDIA RTX A6000

# Cloud 類型：COMMUNITY（較便宜、容量較多）或 SECURE。預設 COMMUNITY。
# 若某資料中心 Secure 配不到卡，可改 COMMUNITY 重試。
RUNPOD_CLOUD_TYPE=COMMUNITY

# pod 使用的容器映像（含 ComfyUI / 訓練框架的 template image）。
RUNPOD_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

# 容器磁碟大小 (GB)。
RUNPOD_CONTAINER_DISK_GB=30

# ── 訓練 ─────────────────────────────────────────────────
# 這次訓練的概念名稱，決定 pod 上資料夾 /workspace/datasets/<concept>/ 與輸出檔名。
TRAIN_CONCEPT=stcklnd

# 觸發詞（caption 前綴用的字）。
TRAIN_TRIGGER=stcklnd

# LoRA 超參數。
TRAIN_RANK=16
TRAIN_ALPHA=8
TRAIN_LR=1e-4
TRAIN_STEPS=1500

# base 模型在 Network Volume 上的相對路徑（沿用 setup_volume.sh 下載的檔）。
TRAIN_BASE_MODEL=models/checkpoints/dreamshaper_xl_v2_turbo.safetensors

# ── rclone → Google Drive（路線 A：user OAuth）────────────
# 本機 `rclone config` 建好 drive remote 後，從 rclone.conf 取出整段 [remote] 內容
# （不含中括號標頭），把多行壓成單行（用 \n 連接）或保留多行貼進來。
# 內含 OAuth token，等同 Drive 存取權，務必勿入版控。
RCLONE_DRIVE_CONFIG=

# 同步目的地：rclone remote 名稱:路徑。例 gdrive:lora-outputs/stcklnd
GDRIVE_DEST_PATH=gdrive:lora-outputs

# ── 行為旗標 ─────────────────────────────────────────────
# 訓練結束後是否保留 pod（true 則不自動回收，需自行回收以免持續計費）。
KEEP_POD=false
