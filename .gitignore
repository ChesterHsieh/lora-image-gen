*.ckpt
*.pt
*.bin

# 機密 / 環境設定（含 API key、rclone token），只提交範本
.env
!.env.example

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
venv/

# 測試 / 覆蓋率產物
.pytest_cache/
.coverage
htmlcov/
