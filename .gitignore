# 訓練資料與產出（大檔，不入版控）
datasets/**
!datasets/.gitkeep
outputs/**
!outputs/.gitkeep

# 資料準備的工作目錄（大量圖片 + 個人整理的 csv，不入版控）
dataset_prep/raw_cards/
dataset_prep/cropped/
